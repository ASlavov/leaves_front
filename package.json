{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "nuxt build && playwright test",
    "test:e2e:ui": "nuxt build && playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --no-warn-ignored",
      "prettier",
      "vitest related --run --passWithNoTests"
    ]
  },
  "dependencies": {
    "@heroicons/vue": "^2.1.5",
    "@nuxtjs/color-mode": "^3.4.4",
    "@pinia/nuxt": "^0.10.0",
    "@preact/signals": "^2.0.0",
    "@schedule-x/calendar": "^2.4.0",
    "@schedule-x/event-modal": "^2.4.1",
    "@schedule-x/events-service": "^2.4.0",
    "@schedule-x/theme-default": "^2.4.0",
    "@schedule-x/vue": "^2.3.0",
    "@vueuse/core": "^11.1.0",
    "chart.js": "^4.4.4",
    "date-fns": "^4.1.0",
    "flatpickr": "^4.6.13",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.13.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.3.0",
    "preact": "^10.24.2",
    "vue": "latest",
    "vue-chartjs": "^5.3.1",
    "vue3-toastify": "^0.2.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.0",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.44",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.10",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "vue": "latest"
  }
}